# Optional overrides (defaults work for public venue pages)
# WCT_DATA_DIR=data
# WCT_CONFIG=config.yaml
# WCT_USER_AGENT=WorldCupTracker/0.1 (+https://github.com/yourname/WorldCupTracker)
# WCT_HTTP_TIMEOUT=30

# Pushover (https://pushover.net/) — enable notifications.enabled in config.yaml
# PUSHOVER_USER_KEY=your_user_key
# PUSHOVER_API_TOKEN=your_application_api_token
